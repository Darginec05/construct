{
  "name": "@construct/nodes",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": [
    "./dist/index.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "tsc -p tsconfig.json && tsc -p tsconfig.examples.json && node examples-dist/smoke.js",
    "example:mcp": "tsc -p tsconfig.json && tsc -p tsconfig.examples.json && node examples-dist/mcp-flow.js",
    "clean": "rm -rf dist examples-dist .turbo"
  },
  "dependencies": {
    "@construct/dsl": "^0.0.0",
    "@construct/engine": "^0.0.0",
    "@construct/providers": "^0.0.0",
    "@construct/rag": "^0.0.0",
    "@construct/tools": "^0.0.0"
  },
  "devDependencies": {
    "@construct/mcp": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Darginec05/construct.git",
    "directory": "packages/nodes"
  },
  "homepage": "https://github.com/Darginec05/construct#readme",
  "bugs": "https://github.com/Darginec05/construct/issues"
}
