{
  "name": "@construct/nodes",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": ["./dist/index.js"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "tsc -p tsconfig.json && tsc -p tsconfig.examples.json && node examples-dist/smoke.js",
    "clean": "rm -rf dist examples-dist .turbo"
  },
  "dependencies": {
    "@construct/dsl": "*",
    "@construct/engine": "*",
    "@construct/providers": "*",
    "@construct/rag": "*",
    "@construct/tools": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
