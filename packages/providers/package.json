{
  "name": "@construct/providers",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "tsc -p tsconfig.json && tsc -p tsconfig.examples.json && node examples-dist/smoke.js",
    "clean": "rm -rf dist examples-dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@google/genai": "^0.7.0",
    "openai": "^4.77.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Darginec05/construct.git",
    "directory": "packages/providers"
  },
  "homepage": "https://github.com/Darginec05/construct#readme",
  "bugs": "https://github.com/Darginec05/construct/issues"
}
