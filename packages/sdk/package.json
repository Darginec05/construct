{
  "name": "@construct/sdk",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run",
    "smoke": "tsc -p tsconfig.json && tsc -p tsconfig.examples.json && node examples-dist/validate-all.js",
    "clean": "rm -rf dist examples-dist .turbo"
  },
  "dependencies": {
    "@construct/dsl": "*",
    "@construct/tools": "*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@construct/engine": "*",
    "@construct/nodes": "*"
  },
  "peerDependenciesMeta": {
    "@construct/engine": { "optional": true },
    "@construct/nodes": { "optional": true }
  },
  "devDependencies": {
    "@construct/engine": "*",
    "@construct/nodes": "*",
    "@construct/providers": "*",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
