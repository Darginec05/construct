# Copy to `.env` (gitignored) and fill in. The server loads this file on start;
# without it, the real process environment is used (prod / CI).

# --- Provider keys (set the ones your flows actually use) --------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...            # or GOOGLE_API_KEY

# --- Server config ----------------------------------------------------------
# PORT=8787
# CONSTRUCT_DB=./construct.db   # omit for an in-memory (ephemeral) store
# CONSTRUCT_API_KEY=secret      # omit to leave the API open (no bearer token)
